{
  "name": "mothercore",
  "private": true,
  "version": "0.0.1",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "npm run electron:dev",
    "build": "npm run build:preload && tsc -b && vite build && electron-builder",
    "build:preload": "tsc -p tsconfig.preload.json",
    "preview": "vite preview",
    "lint": "eslint .",
    "start": "electron .",
    "electron:dev": "npm run build:preload && concurrently \"vite\" \"npm run electron:start\"",
    "electron:build": "vite build && electron-builder",
    "electron:start": "wait-on tcp:5173 && electron ."
  },
  "dependencies": {
    "@types/bcrypt": "^5.0.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.6.0",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.2.10",
    "lucide-react": "^0.379.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^3.4.3",
    "three": "^0.162.0",
    "uuid": "^9.0.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.13",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.7",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.162.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.3.1",
    "electron-builder": "^24.13.3",
    "eslint": "^9.29.0",
    "github-release-cli": "^2.1.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.0",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.mothercore.digitallibrary",
    "productName": "MotherCore Digital Library",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
