{
  "name": "mothercore",
  "private": true,
  "version": "0.0.1",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "npm run electron:dev",
    "build": "npm run build:preload && tsc -b && vite build && electron-builder",
    "build:preload": "tsc -p tsconfig.preload.json",
    "preview": "vite preview",
    "lint": "eslint .",
    "start": "electron .",
    "electron:dev": "npm run electron:build && npm run electron:start",
    "electron:build": "npm run build:preload && tsc -b && vite build",
    "electron:start": "electron .",
    "release": "electron-builder --publish always"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@types/bcrypt": "^5.0.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "electron-updater": "^6.6.2",
    "framer-motion": "^11.2.10",
    "lucide-react": "^0.379.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-error-boundary": "^6.0.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^3.4.3",
    "three": "^0.162.0",
    "uuid": "^9.0.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.13",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.7",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.162.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.3.1",
    "electron-builder": "^24.13.3",
    "eslint": "^9.29.0",
    "github-release-cli": "^2.1.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.0",
    "vite-electron-plugin": "^0.8.3",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vite-plugin-svgr": "^4.3.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.mothercore.digitallibrary",
    "productName": "MotherCore Digital Library",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "publish": {
      "provider": "github",
      "private": false,
      "releaseType": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
